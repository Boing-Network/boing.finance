# Etherscan API (optional - for higher rate limits)
# Get from: https://etherscan.io/apis
REACT_APP_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Solana (optional - defaults to devnet)
# Set to 'mainnet' for production
REACT_APP_SOLANA_NETWORK=devnet
REACT_APP_SOLANA_DEVNET_RPC=https://api.devnet.solana.com
REACT_APP_SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com

# Note: API keys in this file are exposed to the frontend bundle
# Only use keys that are safe to expose (public API keys)
# For sensitive keys, use backend environment variables

