# Environment Variables for boing.finance Frontend
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# Application Environment (used by src/config.js for staging vs production bundles)
REACT_APP_ENV=development
# Options: development, staging, production (CI uses REACT_APP_ENV=staging|production)

# Backend API URL (optional - defaults to config.js values)
REACT_APP_BACKEND_URL=https://boing-api-prod.nico-chikuji.workers.dev

# IPFS Storage API Keys (optional - R2 is used by default)
# Get these from respective service providers:
# - Pinata: https://app.pinata.cloud/
# - Infura: https://infura.io/
# - Web3.Storage: https://web3.storage/
# - Storacha: https://console.storacha.network/

REACT_APP_PINATA_API_KEY=your_pinata_jwt_token_here
REACT_APP_INFURA_PROJECT_ID=your_infura_project_id_here
REACT_APP_INFURA_PROJECT_SECRET=your_infura_project_secret_here
REACT_APP_WEB3_STORAGE_API_KEY=your_web3_storage_token_here
REACT_APP_STORACHA_API_KEY=your_storacha_did_key_here
REACT_APP_NFT_STORAGE_API_KEY=your_nft_storage_key_here

# Blockchain RPC URLs (optional - public fallbacks in config/networks.js)
# For mainnet production, use Infura/Alchemy for reliability
REACT_APP_ETHEREUM_RPC_URL=https://eth.llamarpc.com
REACT_APP_POLYGON_RPC_URL=https://polygon-rpc.com
REACT_APP_BSC_RPC_URL=https://bsc-dataseed.binance.org
REACT_APP_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
REACT_APP_OPTIMISM_RPC_URL=https://mainnet.optimism.io
REACT_APP_BASE_RPC_URL=https://mainnet.base.org
REACT_APP_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Frontend depends on `boing-sdk` via `file:../boing.network/boing-sdk` in package.json.
# CI checks out that repo next to this one; locally symlink or clone: `boing.finance/boing.network` → sibling `boing.network` (see repo .gitignore).
# Cross-repo handoff (Express, Observer, partner dApps): https://github.com/Boing-Network/boing.network/blob/main/docs/HANDOFF-DEPENDENT-PROJECTS.md

# Boing Network L1 testnet (optional — defaults to https://testnet-rpc.boing.network/)
REACT_APP_BOING_TESTNET_RPC_URL=https://testnet-rpc.boing.network/
# Set to 1 to call the RPC URL directly from the browser (requires CORS on the node). Default uses same-origin /api/boing-rpc.
# REACT_APP_BOING_TESTNET_RPC_DIRECT=1

# Native DEX on Boing L1 (6913) — defaults match live stack on https://testnet-rpc.boing.network (see boing.network docs/NATIVE-DEX-OPERATOR-DEPLOYMENT-RECORD.md Appendix B).
# `boing-sdk` embedded constants + `boing_getNetworkInfo` end_user hints merge in BoingNativeDexIntegrationContext; env overrides win at build time.

# REACT_APP_BOING_NATIVE_AMM_POOL=0x7247ddc3180fdc4d3fd1e716229bfa16bad334a07d28aa9fda9ad1bfa7bdacc3
# REACT_APP_BOING_NATIVE_VM_DEX_FACTORY=0x58112627fc84618a27b82e9af82bc9a51761c6d3cca1260c93d56d22b6c481a1
# REACT_APP_BOING_NATIVE_VM_SWAP_ROUTER=0xf801cd1aa5ec402f89a2f394b49e6b0c136264d8945b16a4a6a81a188b18acc1
# REACT_APP_BOING_NATIVE_DEX_LEDGER_ROUTER_V2=0x33334ff73c44c93335ac5e69938a52ea65fa77b062d1961ed22c131adaa31e0f
# REACT_APP_BOING_NATIVE_DEX_LEDGER_ROUTER_V3=0x2c90ffcddeb2683219b4b8143a91d7b93f249bcb0d9523c8b4f2111de668b79a
# REACT_APP_BOING_NATIVE_AMM_LP_VAULT=0x937d09ee8e4dcc521c812566ad4930792e74ad004ecb3ae2cc73dc015813aa8d
# REACT_APP_BOING_NATIVE_AMM_LP_SHARE_TOKEN=0x101201403f573e5b1d6d5c6b93d52d12c68957f4a228d5dad76e78c747044421

# Optional — liquidity locker (not part of every full-stack deploy)
# REACT_APP_BOING_NATIVE_VM_LIQUIDITY_LOCKER=0x…64_hex…

# Optional — inclusive fromBlock for factory `register_pair` logs (`fetchNativeDexDirectorySnapshot`). When set, the app merges extra CP pools into `BoingNativeDexIntegrationContext` for `findBestCpRoute` / multihop-style quotes. Factory must resolve via `boing_getNetworkInfo` or REACT_APP_BOING_NATIVE_VM_DEX_FACTORY.
# REACT_APP_BOING_NATIVE_DEX_REGISTER_LOG_FROM_BLOCK=0

# L1 DEX discovery (`boing_listDexTokens` / `boing_listDexPools`) — requires boing-sdk >= 0.3.0 and a node that implements the methods.
# REACT_APP_BOING_NATIVE_DEX_DISCOVERY_POOLS=1
# REACT_APP_BOING_NATIVE_DEX_DISCOVERY_MAX_PAGES=100
# REACT_APP_BOING_NATIVE_DEX_DISCOVERY_MIN_LIQUIDITY_WEI=
# REACT_APP_BOING_NATIVE_DEX_DISCOVERY_MIN_RESERVE_PRODUCT=
# Set to 1 to run boing-sdk preflightRpc() during integration refresh (extra probes; shows in Developer tools).
# REACT_APP_BOING_NATIVE_DEX_DISCOVERY_PREFLIGHT=1

# Optional — indexer **stats** JSON URL (pools + history), not the D1 directory API:
#   • Cloudflare Pages same-origin: `/api/native-dex-indexer-stats`
#   • Worker stats endpoint: `https://boing-native-dex-indexer.<subdomain>.workers.dev/stats` (or `/` if that serves stats)
#   • Static/R2 URL to `native-dex-indexer-stats.json` from CI
# REACT_APP_BOING_NATIVE_DEX_INDEXER_STATS_URL=https://example.com/native-dex-stats.json
# REACT_APP_BOING_NATIVE_DEX_TOKEN_USD_JSON={"default":"1"}
# REACT_APP_BOING_NATIVE_DEX_ORACLE_MAP_JSON={"0x…64hex…":{"coingeckoId":"tether","decimals":6}}
# REACT_APP_BOING_NATIVE_DEX_VAULT_POOL_MAP_JSON=[{"vaultHex":"0x…","poolHex":"0x…","shareTokenHex":"0x…"}]
# REACT_APP_BOING_NATIVE_DEX_RESERVE_SAMPLE_MS=60000
# REACT_APP_BOING_NATIVE_DEX_SWAP_LOG_SCAN_BLOCKS=5000

# Same-origin stats (Cloudflare Pages): deploy with functions/api/native-dex-indexer-stats.js, then:
# REACT_APP_BOING_NATIVE_DEX_INDEXER_STATS_URL=/api/native-dex-indexer-stats
# Worker **base URL** for D1 directory (`GET /v1/directory/pools`, `/v1/directory/meta`, …) — merged into indexer `pools[]` by poolHex.
# Not served from Pages by default (see boing.network `workers/native-dex-indexer` + HANDOFF_BOING_FINANCE_NATIVE_DEX_AND_DIRECTORY.md).
# REACT_APP_BOING_NATIVE_DEX_DIRECTORY_BASE_URL=https://boing-native-dex-indexer.<you>.workers.dev
# REACT_APP_BOING_NATIVE_DEX_DIRECTORY_MAX_POOLS=2000

# CLI-only (npm run indexer:native-dex): NATIVE_DEX_INDEXER_RPC_URL, NATIVE_DEX_INDEXER_OUT_PATH,
# NATIVE_DEX_INDEXER_STATE_PATH, NATIVE_DEX_INDEXER_REGISTER_FROM_BLOCK, NATIVE_DEX_INDEXER_LOG_SCAN_BLOCKS
# Public RPC may 403 Node fetch on GitHub Actions — buildNativeDexIndexerStats adds a browser-like User-Agent when
# GITHUB_ACTIONS=true. Override: NATIVE_DEX_INDEXER_RPC_USER_AGENT=… ; disable: NATIVE_DEX_INDEXER_RPC_NO_BROWSER_UA=1
# Optional CLI / buildNativeDexIndexerStats: JSON map token id → USD per atomic unit (same idea as REACT_APP_BOING_NATIVE_DEX_TOKEN_USD_JSON)
# NATIVE_DEX_INDEXER_TOKEN_USD_JSON={"default":"1"}
# Optional: extra tokenDirectory rows merged into indexer JSON (symbol/name for arbitrary ids)
# NATIVE_DEX_INDEXER_TOKEN_DIRECTORY_JSON=[{"id":"0x…64hex…","symbol":"FOO","name":"Foo"}]
#
# Cloudflare Pages (functions/api/native-dex-indexer-stats.js) — set in dashboard or wrangler.toml [[kv_namespaces]]:
#   NATIVE_DEX_INDEXER_KV  (binding; KV key native_dex_indexer_state_v1 for durable history)
#   BOING_TESTNET_RPC_URL, NATIVE_DEX_INDEXER_API_DISABLE, NATIVE_DEX_INDEXER_REGISTER_FROM_BLOCK, NATIVE_DEX_INDEXER_LOG_SCAN_BLOCKS
#
# Where “environment” lives:
#   • SPA `REACT_APP_*` baked at CI build → `env/github-build.production.env` / `env/github-build.staging.env` (git).
#   • Pages Functions (RPC proxy, on-demand indexer) non-secrets → `wrangler.toml` [vars] / [env.production.vars] / [env.preview.vars].
#   • GitHub Actions secrets → `CLOUDFLARE_API_TOKEN`, `CLOUDFLARE_ACCOUNT_ID` (deploy + optional R2 upload only).
#   • Scheduled native-dex-indexer **JSON** job (GitHub runners) → defaults in `env/github-native-dex-indexer.env` (git);
#     optional large JSON still via repository Variables `NATIVE_DEX_INDEXER_TOKEN_USD_JSON` / `_TOKEN_DIRECTORY_JSON`.
#     Optional R2 upload gate: repository Variables `NATIVE_DEX_INDEXER_R2_BUCKET` + `NATIVE_DEX_INDEXER_R2_OBJECT_KEY` (not secrets).
#
# Indexer HTTP (Pages Function / Worker): optional query pools_page=0 & pools_page_size=1..500 to paginate pools[] only.

# Optional — public URL for L1 DEX docs (shown in in-app banners). Example: GitHub blob or Pages URL to docs/boing-l1-vs-evm-dex.md
# REACT_APP_BOING_L1_DEX_DOCS_URL=https://github.com/your-org/boing.finance/blob/main/docs/boing-l1-vs-evm-dex.md

# Unsigned contract_call dry-run (boing-node): use exact method name. Optional strict probe requires boing_rpcSupportedMethods to list it.
# REACT_APP_BOING_RPC_UNSIGNED_SIMULATE_METHOD=boing_simulateContractCall
# REACT_APP_BOING_RPC_UNSIGNED_SIMULATE_STRICT_PROBE=1

# Set to 1 when native VM factory/router swap UI is fully wired (hides “integration pending” banners).
# REACT_APP_BOING_NATIVE_VM_DEX_UI=1

# Native fungible template — Boing VM deploy bytecode (even-length 0x hex). Read by boing-sdk `resolveReferenceFungibleTemplateBytecodeHex`.
# See boing.network `docs/BOING-CANONICAL-DEPLOY-ARTIFACTS.md`. Legacy alias: REACT_APP_BOING_REFERENCE_TOKEN_BYTECODE (still honored).
# REACT_APP_BOING_REFERENCE_FUNGIBLE_TEMPLATE_BYTECODE_HEX=0x…your_even_length_hex…
# REACT_APP_BOING_REFERENCE_TOKEN_BYTECODE=0x…

# Native NFT collection template — Boing VM deploy bytecode for Create NFT → “Deploy native collection”. Read by boing-sdk
# `resolveReferenceNftCollectionTemplateBytecodeHex`. Without this (and no embedded template in your SDK build), paste hex under Advanced in the wizard.
# Legacy alias still honored by the app: REACT_APP_BOING_REFERENCE_NFT_BYTECODE_HEX.
# REACT_APP_BOING_REFERENCE_NFT_COLLECTION_TEMPLATE_BYTECODE_HEX=0x…
# REACT_APP_BOING_REFERENCE_NFT_BYTECODE_HEX=0x…

# Expansion networks (optional - public RPCs used by default)
REACT_APP_AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
REACT_APP_FANTOM_RPC_URL=https://rpc.ftm.tools
REACT_APP_ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
REACT_APP_LINEA_RPC_URL=https://rpc.linea.build
REACT_APP_SCROLL_RPC_URL=https://rpc.scroll.io
REACT_APP_POLYGON_ZKEVM_RPC_URL=https://zkevm-rpc.com
REACT_APP_MANTLE_RPC_URL=https://rpc.mantle.xyz
REACT_APP_BLAST_RPC_URL=https://rpc.blast.io
REACT_APP_OPBNB_RPC_URL=https://opbnb-mainnet-rpc.bnbchain.org
REACT_APP_MODE_RPC_URL=https://mainnet.mode.network

