{
  "name": "dex-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@noble/ed25519": "^2.2.0",
    "@noble/hashes": "^1.6.0",
    "@farcaster/miniapp-sdk": "^0.2.1",
    "@heroicons/react": "^2.2.0",
    "@metaplex-foundation/mpl-token-metadata": "^2.13.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.6.0",
    "boing-sdk": "file:../boing.network/boing-sdk",
    "buffer": "^6.0.3",
    "ethers": "^6.8.1",
    "framer-motion": "^10.16.4",
    "i18next": "^23.7.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "prebuild": "node scripts/update-service-worker-version.js && node scripts/generate-version-manifest.js && node scripts/generate-brand-assets.mjs && node scripts/generate-favicon.mjs",
    "build": "npm run generate-manifest && cross-env CI=false vite build",
    "build:prod": "cross-env CI=false REACT_APP_ENV=production vite build",
    "build:staging": "cross-env CI=false REACT_APP_ENV=staging vite build",
    "preview": "vite preview",
    "test": "echo \"No unit tests configured\" && exit 0",
    "postinstall": "node scripts/postinstall-boing-sdk.mjs",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "smoke:boing-rpc": "node scripts/smoke-boing-testnet-rpc.mjs",
    "setup-base": "node scripts/setup-base-miniapp.js",
    "generate-manifest": "node scripts/generate-manifest.js",
    "generate-brand-assets": "node scripts/generate-brand-assets.mjs",
    "generate-favicon": "node scripts/generate-favicon.mjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "globals": {
      "BigInt": "readonly"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "to-ico": "^1.1.5",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  },
  "overrides": {
    "@solana/codecs": "2.3.0",
    "@solana/codecs-core": "2.3.0",
    "@solana/codecs-data-structures": "2.3.0",
    "@solana/codecs-numbers": "2.3.0",
    "@solana/codecs-strings": "2.3.0"
  }
}
