# Baked into the Vite bundle on production CI builds (public values only).
# Edit this file in git — not GitHub Actions Variables.
#
# Stats: same-origin Pages Function (deployed with this repo) or full URL to Worker /stats or static JSON.
REACT_APP_BOING_NATIVE_DEX_INDEXER_STATS_URL=/api/native-dex-indexer-stats
# Worker origin for D1 directory (no path). Leave empty to skip directory merge until you have a Worker URL.
REACT_APP_BOING_NATIVE_DEX_DIRECTORY_BASE_URL=

# Reference NFT collection template (boing-execution dump_reference_token_artifacts, 3rd 0x line).
REACT_APP_BOING_REFERENCE_NFT_COLLECTION_TEMPLATE_BYTECODE_
