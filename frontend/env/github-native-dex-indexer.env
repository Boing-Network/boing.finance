# Used by `.github/workflows/native-dex-indexer.yml` on GitHub-hosted runners (not Cloudflare).
# Edit in git instead of repository Variables for these keys.
NATIVE_DEX_INDEXER_RPC_URL=https://testnet-rpc.boing.network/
NATIVE_DEX_INDEXER_LOG_SCAN_BLOCKS=8000
# Optional: set to a non-negative block height to scan factory `register_pair` logs from that height upward.
# NATIVE_DEX_INDEXER_REGISTER_FROM_BLOCK=0
